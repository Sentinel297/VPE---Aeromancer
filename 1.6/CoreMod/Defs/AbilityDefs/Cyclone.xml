	</modExtensions>
</VEF.Abilities.AbilityDef>
	 
<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_HypoxiaSTNL</defName>
	<label>Hypoxia</label>
	<description>Rip out the air from the target's lungs, causing them to show signs of hypoxia, repeated uses will worsen the effect until death once hypoxia reaches 100%.</description>
	<iconPath>UI_CycloneSTNL/Abilities/Hypoxia</iconPath>
	<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
	<castTime>45</castTime>
	<range>14.9</range>
	<targetMode>Pawn</targetMode>
	<targetingParameters>
		<canTargetLocations>false</canTargetLocations>
		<canTargetSelf>true</canTargetSelf>
		<canTargetAnimals>true</canTargetAnimals>
		<canTargetPawns>true</canTargetPawns>
		<canTargetHumans>true</canTargetHumans>
		<canTargetItems>true</canTargetItems>
		<canTargetMechs>false</canTargetMechs>
	</targetingParameters>
	<needsTicking>true</needsTicking>
	<castSound>VPE_FireBeam_Cast</castSound>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_CycloneSTNL</path>
			<level>2</level>
			<order>1</order>
			<psyfocusCost>0.05</psyfocusCost>
			<entropyGain>10</entropyGain>
			<prerequisites>
				<li>VPE_AirPushSTNL</li>
			</prerequisites>
		</li>
		<li Class="VEF.Abilities.AbilityExtension_Hediff">
			<hediff>VPE_Cyclone_HypoxiaSTNL</hediff>
			<severity>0.49</severity>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>
	 
