<Defs>	

<!-- Level 1 -->

<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_AirPushSTNL</defName>
	<label>Push</label>
	<description>Conjure a strong gust of wind, pushing the target creature away from the caster.</description>
	<iconPath>UI_CycloneSTNL/Abilities/Push</iconPath>
	<abilityClass>VPE_Cyclone.Ability_WindPush</abilityClass>
	<castTime>120</castTime>
	<range>15.5</range>
	<durationTime>675000</durationTime>
	<targetMode>Pawn</targetMode>
	<targetingParameters>
		<canTargetLocations>false</canTargetLocations>
		<canTargetSelf>true</canTargetSelf>
		<canTargetAnimals>true</canTargetAnimals>
		<canTargetPawns>true</canTargetPawns>
		<canTargetHumans>true</canTargetHumans>
		<canTargetItems>true</canTargetItems>
		<canTargetMechs>true</canTargetMechs>
	</targetingParameters>
	<needsTicking>true</needsTicking>
	<castSound>VPE_EnergyDump_Cast</castSound>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_CycloneSTNL</path>
			<level>1</level>
			<order>1</order>
			<psyfocusCost>0.01</psyfocusCost>
			<entropyGain>5</entropyGain>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

