 <!-- Level 4 -->
 
<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_PersonalAtmoSTNL</defName>
	<label>Aero Shield</label>
	<description>Temporarily surround the targets with a miniature self-sustaining atmosphere that will allow them to breathe in the vacuum of space and render them immune to airborne toxins. Will provide 30°c of insulation.</description>
	<iconPath>UI_CycloneSTNL/Abilities/Atmo</iconPath>
	<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
	<castTime>120</castTime>
	<range>14.9</range>
	<radius>2.5</radius>
	<hasAoE>True</hasAoE>
	<durationTime>30000</durationTime>
	<durationTimeStatFactors>
		<PsychicSensitivity>1</PsychicSensitivity>
	</durationTimeStatFactors>
	<chance>0</chance>
	<targetMode>Location</targetMode>
	<targetingParameters>
		<canTargetLocations>true</canTargetLocations>
		<canTargetSelf>false</canTargetSelf>
		<canTargetAnimals>false</canTargetAnimals>
		<canTargetPawns>false</canTargetPawns>
		<canTargetHumans>false</canTargetHumans>
		<canTargetItems>false</canTargetItems>
		<canTargetMechs>false</canTargetMechs>
		<!-- Why -->
	</targetingParameters>
	<targetingParametersForAoE>
		<canTargetLocations>false</canTargetLocations>
		<canTargetSelf>true</canTargetSelf>
		<canTargetAnimals>true</canTargetAnimals>
		<canTargetPawns>true</canTargetPawns>
		<canTargetHumans>true</canTargetHumans>
		<canTargetItems>false</canTargetItems>
		<canTargetMechs>true</canTargetMechs>
	</targetingParametersForAoE>
	<needsTicking>true</needsTicking>
	<castSound>VPE_Psyring_Cast</castSound>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_CycloneSTNL</path>
			<level>4</level>
			<order>1</order>
			<psyfocusCost>0.15</psyfocusCost>
			<entropyGain>55</entropyGain>
			<prerequisites>
				<li>VPE_UpdraftSTNL</li>
			</prerequisites>
		</li>
		<li Class="VEF.Abilities.AbilityExtension_ExtraHediffs">
			<onTarget>
				<li>PersonalAtmoSTNL</li>
			</onTarget>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_TornadoSTNL</defName>
	<label>Tornado</label>
