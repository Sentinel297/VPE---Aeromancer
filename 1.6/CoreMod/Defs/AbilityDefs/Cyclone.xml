<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
	<defName>VPE_DeltaStreamSTNL</defName>
	<label>Delta Stream</label>
	<description>Alter the local weather to conjure strong winds that will override other active weather based conditions, additionally, allies will obtain the tailwind hediff, boosting their movement speed while enemies will obtain the headwind hediff, slowing them down.</description>
	<iconPath>UI_CycloneSTNL/Abilities/Delta</iconPath>
	<abilityClass>VPE_Cyclone.Ability_ForceCondition</abilityClass>
	<durationTime>60000</durationTime>
	<durationTimeStatFactors>
	<PsychicSensitivity>1</PsychicSensitivity>
	</durationTimeStatFactors>
	<castTime>180</castTime>
	<chance>0</chance>
	<targetMode>Self</targetMode>
	<castSound>Psycast_Neuroquake_Effect</castSound>
	<showUndrafted>true</showUndrafted>
	<modExtensions>
		<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
			<path>VPE_CycloneSTNL</path>
			<level>4</level>
			<order>3</order>
			<psyfocusCost>0.5</psyfocusCost>
			<entropyGain>50</entropyGain>
			<prerequisites>
				<li>VPE_DisarmingGaleSTNL</li>
			</prerequisites>
		</li>
		<li Class="VPE_Cyclone.AbilityForceCondiExt">
			<conditionDef>DeltaStreamSTNL</conditionDef>
			<global>false</global>
			<scaleDuraWithSensi>true</scaleDuraWithSensi>
			<aiCanUse>false</aiCanUse>
		</li>
	</modExtensions>
</VEF.Abilities.AbilityDef>

